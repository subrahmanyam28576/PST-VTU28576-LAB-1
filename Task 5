public class PairingElements {
    public static void main(String[] args) {
        int[] numbers = {10, 20, 35, 55, 40, 50};

        for (int i = 0; i < numbers.length - 1; i += 2) {
            System.out.println("(" + numbers[i] + ", " + numbers[i + 1] + ")");
        }

     
           
    }
}
